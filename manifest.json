{
  "manifest_version": 3,
  "name": "Quick Note 📝",
  "version": "1.0",
  "description": "Quickly jot down your important things!!",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "webNavigation", "storage"],
  "icons": {
    "48": "icon.png"
  },
  "host_permissions": ["https://api.example.com/*"],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+N",
        "mac": "Alt+N"
      },
      "description": "Open Quick Note"
    }
  }
}
